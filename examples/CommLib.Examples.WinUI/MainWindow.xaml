<Window
    x:Class="CommLib.Examples.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="6">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="CommLib Device Lab" />
                <TextBlock TextWrapping="Wrap"
                           Text="Connect to TCP, UDP, multicast, or serial endpoints, send a MessageModel, and watch inbound messages in the live log." />
                <TextBlock x:Name="StatusTextBlock"
                           FontWeight="SemiBold"
                           Text="Disconnected" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="420" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="16">
                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Session Setup" />

                            <TextBlock Text="Transport" />
                            <ComboBox x:Name="TransportTypeComboBox"
                                      SelectedIndex="0"
                                      SelectionChanged="TransportTypeComboBox_SelectionChanged">
                                <ComboBoxItem Content="TCP" Tag="tcp" />
                                <ComboBoxItem Content="UDP" Tag="udp" />
                                <ComboBoxItem Content="Multicast" Tag="multicast" />
                                <ComboBoxItem Content="Serial" Tag="serial" />
                            </ComboBox>

                            <TextBlock Text="Device Id" />
                            <TextBox x:Name="DeviceIdTextBox" Text="device-lab" />

                            <TextBlock Text="Display Name" />
                            <TextBox x:Name="DisplayNameTextBox" Text="Device Lab" />

                            <TextBlock Text="Default Timeout (ms)" />
                            <TextBox x:Name="DefaultTimeoutTextBox" Text="3000" />

                            <TextBlock Text="Max Pending Requests" />
                            <TextBox x:Name="MaxPendingTextBox" Text="8" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="TcpSectionBorder" BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="TCP Target" />
                            <TextBlock Text="Host" />
                            <TextBox x:Name="TcpHostTextBox" Text="127.0.0.1" />
                            <TextBlock Text="Port" />
                            <TextBox x:Name="TcpPortTextBox" Text="7001" />
                            <TextBlock Text="Connect Timeout (ms)" />
                            <TextBox x:Name="TcpConnectTimeoutTextBox" Text="1000" />
                            <TextBlock Text="Buffer Size" />
                            <TextBox x:Name="TcpBufferSizeTextBox" Text="1024" />
                            <CheckBox x:Name="TcpNoDelayCheckBox" Content="Disable Nagle (NoDelay)" IsChecked="True" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="UdpSectionBorder" BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16" Visibility="Collapsed">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="UDP Target" />
                            <TextBlock Text="Local Port" />
                            <TextBox x:Name="UdpLocalPortTextBox" Text="0" />
                            <TextBlock Text="Remote Host" />
                            <TextBox x:Name="UdpRemoteHostTextBox" Text="127.0.0.1" />
                            <TextBlock Text="Remote Port" />
                            <TextBox x:Name="UdpRemotePortTextBox" Text="7002" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="MulticastSectionBorder" BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16" Visibility="Collapsed">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Multicast Target" />
                            <TextBlock Text="Group Address" />
                            <TextBox x:Name="MulticastGroupTextBox" Text="239.0.0.241" />
                            <TextBlock Text="Port" />
                            <TextBox x:Name="MulticastPortTextBox" Text="7004" />
                            <TextBlock Text="TTL" />
                            <TextBox x:Name="MulticastTtlTextBox" Text="1" />
                            <TextBlock Text="Local Interface (optional)" />
                            <TextBox x:Name="MulticastLocalInterfaceTextBox" />
                            <CheckBox x:Name="MulticastLoopbackCheckBox" Content="Enable loopback" IsChecked="True" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="SerialSectionBorder" BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16" Visibility="Collapsed">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Serial Target" />
                            <TextBlock Text="Port Name" />
                            <TextBox x:Name="SerialPortNameTextBox" Text="COM3" />
                            <TextBlock Text="Baud Rate" />
                            <TextBox x:Name="SerialBaudRateTextBox" Text="115200" />
                            <TextBlock Text="Data Bits" />
                            <TextBox x:Name="SerialDataBitsTextBox" Text="8" />
                            <TextBlock Text="Parity" />
                            <ComboBox x:Name="SerialParityComboBox" SelectedIndex="0">
                                <ComboBoxItem Content="None" />
                                <ComboBoxItem Content="Odd" />
                                <ComboBoxItem Content="Even" />
                                <ComboBoxItem Content="Mark" />
                                <ComboBoxItem Content="Space" />
                            </ComboBox>
                            <TextBlock Text="Stop Bits" />
                            <ComboBox x:Name="SerialStopBitsComboBox" SelectedIndex="1">
                                <ComboBoxItem Content="None" />
                                <ComboBoxItem Content="One" />
                                <ComboBoxItem Content="Two" />
                                <ComboBoxItem Content="OnePointFive" />
                            </ComboBox>
                            <TextBlock Text="Turn Gap (ms)" />
                            <TextBox x:Name="SerialTurnGapTextBox" Text="0" />
                            <TextBlock Text="Read Buffer Size" />
                            <TextBox x:Name="SerialReadBufferTextBox" Text="1024" />
                            <TextBlock Text="Write Buffer Size" />
                            <TextBox x:Name="SerialWriteBufferTextBox" Text="1024" />
                            <CheckBox x:Name="SerialHalfDuplexCheckBox" Content="Use half-duplex timing" IsChecked="False" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Message" />
                            <TextBlock Text="Message Id" />
                            <TextBox x:Name="MessageIdTextBox" Text="100" />
                            <TextBlock Text="Body" />
                            <TextBox x:Name="MessageBodyTextBox"
                                     Height="120"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Text="hello from winui device lab" />

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="ConnectButton" Grid.Column="0" Click="ConnectButton_Click" Content="Connect" />
                                <Button x:Name="DisconnectButton" Grid.Column="1" Click="DisconnectButton_Click" Content="Disconnect" IsEnabled="False" />
                                <Button x:Name="SendButton" Grid.Column="2" Click="SendButton_Click" Content="Send" IsEnabled="False" />
                                <Button Grid.Column="3" Click="ClearLogButton_Click" Content="Clear Log" />
                            </Grid>

                            <TextBlock TextWrapping="Wrap"
                                       Text="This example uses the library's fixed LengthPrefixed + AutoBinary combination. The peer device or test server must use the same framing and serialization rules." />
                        </StackPanel>
                    </Border>

                    <Border BorderBrush="LightGray" BorderThickness="1" CornerRadius="12" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Event Log" />
                            <ListView x:Name="LogListView"
                                      Height="720"
                                      SelectionMode="None" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
